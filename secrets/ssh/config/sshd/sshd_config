Port 2222
HostKey /config/ssh_host_keys/ssh_host_rsa_key
HostCertificate /config/ssh_host_keys/ssh_host_rsa_key-cert.pub
TrustedUserCAKeys /config/sshd/trusted-keys.pem
PasswordAuthentication no
AllowTcpForwarding no
GatewayPorts no
X11Forwarding no
PidFile /config/sshd.pid
Subsystem       sftp    internal-sftp
LogLevel DEBUG3
